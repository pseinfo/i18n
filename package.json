{
  "name": "@pseinfo/i18n",
  "private": true,
  "description": "Centralized localization for the @pseinfo project",
  "license": "MIT",
  "version": "0.0.0",
  "author": {
    "name": "komed3 (Paul Köhler)",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "type": "module",
  "files": [
    "config",
    "declaration",
    "locales",
    "types",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./config": {
      "import": "./config/*.ts",
      "default": "./config/*.ts",
      "types": "./config/*.ts"
    },
    "./declaration": {
      "types": "./declaration/*.d.ts"
    },
    "./locales": {
      "import": "./locales/**/*.ts",
      "default": "./locales/**/*.ts",
      "types": "./locales/**/*.ts"
    },
    "./types": {
      "types": "./types/*.d.ts"
    }
  },
  "scripts": {
    "lint": "npx tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
